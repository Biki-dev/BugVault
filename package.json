{
  "name": "bugvault-ai",
  "displayName": "BugVault AI",
  "description": "Automatic bug memory system — detects errors, remembers fixes, warns you when a bug repeats. With team/shared memory support.",
  "version": "1.0.0",
  "publisher": "biki-dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/biki-dev/BugVault"
  },
  "bugs": {
    "url": "https://github.com/biki-dev/BugVault/issues"
  },
  "icon": "media/icon.png",
  "keywords": [
    "bug",
    "error",
    "memory",
    "ai",
    "debugging",
    "productivity",
    "team"
  ],
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Debuggers",
    "AI",
    "Machine Learning"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bugvault.markSolved",
        "title": "BugVault: Mark as Solved",
        "icon": "$(check)"
      },
      {
        "command": "bugvault.saveFix",
        "title": "BugVault: Edit Fix",
        "icon": "$(edit)"
      },
      {
        "command": "bugvault.showRelatedBugs",
        "title": "BugVault: Show Bug Details",
        "icon": "$(info)"
      },
      {
        "command": "bugvault.openPanel",
        "title": "BugVault: Open Bug Vault Panel",
        "icon": "$(bug)"
      },
      {
        "command": "bugvault.clearSolved",
        "title": "BugVault: Clear Solved Bugs",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bugvault-sidebar",
          "title": "BugVault AI",
          "icon": "media/icon.png"
        }
      ]
    },
    "views": {
      "bugvault-sidebar": [
        {
          "id": "bugvault.recentBugs",
          "name": "Recent Bugs",
          "type": "tree"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "bugvault.clearSolved",
          "when": "view == bugvault.recentBugs",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "BugVault AI",
      "properties": {
        "bugvault.supermemoryUrl": {
          "type": "string",
          "default": "http://localhost:6767",
          "description": "URL of your personal local Supermemory instance.",
          "order": 1
        },
        "bugvault.similarityThreshold": {
          "type": "number",
          "default": 0.82,
          "minimum": 0.5,
          "maximum": 1.0,
          "description": "Minimum semantic similarity score (0.5–1.0) to treat a bug as repeated. Higher = stricter matching.",
          "order": 2
        },
        "bugvault.enableAutoCapture": {
          "type": "boolean",
          "default": true,
          "description": "Automatically capture terminal, diagnostic, and build errors.",
          "order": 3
        },
        "bugvault.sharedMemory.enabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable team/shared memory mode. When on, BugVault connects to the shared Supermemory URL so all developers share one knowledge base.",
          "order": 4
        },
        "bugvault.sharedMemory.url": {
          "type": "string",
          "default": "http://localhost:6767",
          "description": "URL of the shared team Supermemory instance used when sharedMemory.enabled is true.",
          "order": 5
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "npx @vscode/vsce package --no-dependencies",
    "test": "vitest run"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "node-abi": "^3.94.0",
    "node-fetch": "^3.3.2"
  }
}
